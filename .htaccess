<IfModule mod_rewrite.c>
    RewriteEngine On

    DirectoryIndex index.php

    # Let Apache serve existing files and directories directly.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Send all application routes through the front controller.
    RewriteRule ^ index.php [L,QSA]
</IfModule>
